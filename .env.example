# Booking.com Demand API credentials.
# Obtain these from Partner Centre once you are an approved Managed Affiliate Partner.
# See: https://developers.booking.com/demand/docs/getting-started/prerequisites

# API key token (sent as: Authorization: Bearer <token>)
BOOKING_API_KEY=

# Your affiliate id (sent as: X-Affiliate-Id: <id>)
BOOKING_AFFILIATE_ID=

# Optional: override the API base URL (e.g. to point at the sandbox or a newer version).
# Default: https://demandapi.booking.com/3.1
# BOOKING_API_BASE_URL=https://demandapi.booking.com/3.1

# Optional: passphrase used to encrypt credentials at rest when you run `bkng auth login`.
# If unset, `bkng auth login` stores the token in plaintext and warns you.
# BOOKING_CLI_SECRET=
