{
  "name": "booking-cli",
  "version": "0.1.0",
  "description": "One CLI for the Booking.com Demand API — built for humans and AI agents. Unofficial, open source.",
  "type": "module",
  "license": "MIT",
  "author": "WYSIATI",
  "homepage": "https://github.com/WYSIATI/booking-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WYSIATI/booking-cli.git"
  },
  "bugs": {
    "url": "https://github.com/WYSIATI/booking-cli/issues"
  },
  "keywords": [
    "booking.com",
    "cli",
    "mcp",
    "ai-agents",
    "travel",
    "hotels"
  ],
  "bin": {
    "bkng": "dist/index.js",
    "bkng-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.9.0",
    "prettier": "^3.9.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
